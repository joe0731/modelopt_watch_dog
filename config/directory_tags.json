{
  "watched_repo": "NVIDIA/Model-Optimizer",

  "tag_definitions": {
    "torch": "modelopt.torch - PyTorch optimization core library",
    "onnx": "modelopt.onnx - ONNX graph optimization, autocast, ONNX-specific quantization",
    "deploy": "modelopt.deploy - deployment tools, serving, vLLM, TensorRT-LLM integration",
    "quantization": "post-training quantization (PTQ), QAT, QAD, calibration, quantized layers",
    "distillation": "knowledge distillation, teacher-student training",
    "pruning": "model pruning, structured and unstructured",
    "sparsity": "weight sparsity, attention sparsity",
    "speculative_decoding": "speculative decoding, Eagle, Medusa, draft models",
    "export": "model export, torch-to-ONNX conversion",
    "nas": "neural architecture search, hyperparameter optimization",
    "peft": "parameter-efficient fine-tuning, LoRA, adapters",
    "diffusers": "diffusion model optimization (Stable Diffusion, FLUX, etc.)",
    "core": "core utilities, tracing, optimization pipeline, common infrastructure",
    "infra": "CI/CD, build system, GitHub/GitLab config, packaging",
    "docs": "documentation, guides, API reference",
    "tests": "test infrastructure, test utilities",
    "experimental": "experimental features, research prototypes",
    "windows": "Windows platform-specific code and examples"
  },

